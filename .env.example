# ─── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=troque-por-uma-chave-secreta-forte
APP_TITLE=Kraft
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Banco de dados ────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://kraft:kraft@localhost:5432/kraft

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth JWT ─────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── IA (Anthropic Claude) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Storage (Cloudflare R2 ou AWS S3) ────────────────────────────────────────
STORAGE_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=kraft-assets
STORAGE_PUBLIC_URL=https://assets.kraft.app

# ─── Godot ────────────────────────────────────────────────────────────────────
GODOT_BINARY=/usr/local/bin/godot4
GODOT_EXPORT_TEMPLATE_DIR=/root/.local/share/godot/export_templates

# ─── Blender ──────────────────────────────────────────────────────────────────
BLENDER_BINARY=/usr/bin/blender

# ─── Projetos (diretório de trabalho dos workers) ─────────────────────────────
PROJECTS_WORKDIR=/tmp/kraft_projects

# ─── Marketplace ──────────────────────────────────────────────────────────────
PLATFORM_COMMISSION_PERCENT=15
